APP_ENV=local
LOG_LEVEL=INFO

KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_SALES_TOPIC=mm.retail.sales.events.v1
KAFKA_REJECTED_TOPIC=mm.retail.sales.rejected.v1
KAFKA_CONSUMER_GROUP=mm-realtime-sales-analytics-consumer
KAFKA_POLL_TIMEOUT_MS=2000

POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=myanmar_realtime_sales
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

PRODUCER_MIN_DELAY_SECONDS=0.25
PRODUCER_MAX_DELAY_SECONDS=1.50
PRODUCER_INVALID_EVENT_RATE=0.08
PRODUCER_DUPLICATE_EVENT_RATE=0.10
PRODUCER_MAX_BATCH_SIZE=5
